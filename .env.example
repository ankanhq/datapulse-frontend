# Base URL of the DataPulse backend API.
# Local dev defaults to http://localhost:8000 when this is unset (see src/api.js).
# In production (e.g. Vercel) set this to your deployed backend URL, no trailing slash:
#   VITE_API_BASE=https://datapulse-api.onrender.com
VITE_API_BASE=http://localhost:8000
