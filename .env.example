# Base URL of the DataPulse backend API.
# Local dev defaults to http://localhost:8000 when this is unset (see src/api.js).
# In production (e.g. Vercel) set this to your deployed backend URL, no trailing slash:
#   VITE_API_BASE=https://datapulse-api.onrender.com
VITE_API_BASE=http://localhost:8000

# Supabase auth (required — the whole app is gated behind sign-in).
# Find these in your Supabase project: Settings → API. The anon key is public
# and safe to ship in the browser bundle. Never put the service-role key here.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key
